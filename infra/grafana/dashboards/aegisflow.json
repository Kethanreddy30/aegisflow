{
  "title": "AegisFlow Gateway",
  "uid": "aegisflow-main",
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(aegisflow_requests_total)", "legendFormat": "Total"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(aegisflow_cache_hits_total) / (sum(aegisflow_cache_hits_total) + sum(aegisflow_cache_misses_total)) * 100", "legendFormat": "Hit Rate %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 3,
      "title": "Request Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(aegisflow_request_errors_total)", "legendFormat": "Errors"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 4,
      "title": "PII Masking Applied",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(aegisflow_masking_applied_total)", "legendFormat": "Masked"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 5,
      "title": "Request Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(aegisflow_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(aegisflow_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "id": 6,
      "title": "Requests Per Minute",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "rate(aegisflow_requests_total[1m]) * 60", "legendFormat": "RPM"}]
    },
    {
      "id": 7,
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "rate(aegisflow_cache_hits_total[1m])", "legendFormat": "Hits"},
        {"expr": "rate(aegisflow_cache_misses_total[1m])", "legendFormat": "Misses"}
      ]
    },
    {
      "id": 8,
      "title": "Requests by Tenant",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "rate(aegisflow_requests_total[1m])", "legendFormat": "{{tenant_id}}"}]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {}
}
